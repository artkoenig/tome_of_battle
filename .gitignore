# Session-scoped override for the worktree_guard.py PreToolUse hook. Local-only,
# never committed: a routine `git add -A` during a merge would otherwise sweep
# it into the commit and disable the guard permanently for every checkout.
.claude/.worktree-bypass
.scratch/
.antigravity/
e2e-failure.png

# Arbeitsausgabe von scripts/generate_screenshots.js. Nicht zu verwechseln mit
# dem versionierten screenshots/, das die kuratierten README-Bilder enthält.
.screenshots/
.claude/worktrees/

# Lokale Ausgabe des Zustandsbericht-Generators (scripts/project-state/generate.js).
# In CI wird der Bericht direkt ins Pages-Deployment gelegt und nie committet.
.report/

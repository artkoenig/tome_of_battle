)" entryId="ee4c-e8ff-af3a-e186" entryGroupId="f946-561a-0c64-24dd" number="1" type="upgrade" from="group" group="Weapons"><profiles><profile id="a15a-0123-6693-7a50" name="Lance" hidden="false" typeId="7889-42d9-70a0-3ea9" typeName="Weapon" from="entry"><characteristics><characteristic name="Range" typeId="3107-4d1e-9a51-6564"></characteristic><characteristic name="Strength" typeId="6fe4-1ebb-cb04-1378">+2S on charge</characteristic><characteristic name="Special Rules" typeId="a21a-cdc0-4b13-b236">Mounted models only.</characteristic></characteristics></profile></profiles><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="4" /></costs></selection></selections><categories><category id="4cae-a20e-8374-b6cb" name="Blood Dragon" entryId="4cae-a20e-8374-b6cb" primary="false" /></categories></selection></selections><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="80" /></costs><categories><category id="7a1c-d611-c2dc-def1" name="Characters" entryId="7a1c-d611-c2dc-def1" primary="false" /><category id="c16b-f319-2c62-2c12" entryId="c16b-f319-2c62-2c12" name="Heroes" primary="true" /></categories></selection><selection id="yarwsc" name="Wight Lord" entryId="b9c6-93fb-ce3c-965a" number="1" type="unit" from="entry"><rules><rule id="8c78-c9d9-e5ea-0507" name="Wight Blades" hidden="false"><description>Wights are armed with evilly enchanted weapons. Any normal weapon carried by a Wight counts as a magic weapon (but all the normal rules for that weapon still apply) The weapon also has the killing Blow special ability (see page 112 of the Warhammer rulebook). Note that this rule does not apply to any magic weapon that a Wight Lord buys from the magic items list.</description></rule></rules><profiles><profile id="a9a3-6760-b00e-bb3b" name="Wight Lord" hidden="false" typeId="a54a-7f00-29bf-12b1" typeName="Profile" from="entry"><characteristics><characteristic name="Mv" typeId="0e92-d038-82bf-fb41">4</characteristic><characteristic name="WS" typeId="f95b-da01-057
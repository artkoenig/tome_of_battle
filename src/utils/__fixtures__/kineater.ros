01-0578-3bdc">3</characteristic><characteristic name="BS" typeId="4a8b-0c8e-3daf-7901"></characteristic><characteristic name="S" typeId="b690-4bc0-bb73-267b">5</characteristic><characteristic name="T" typeId="8712-f56f-5b22-a720"></characteristic><characteristic name="W" typeId="253a-9b00-4fde-8ac2"></characteristic><characteristic name="I" typeId="dfff-363e-f72a-5a59">2</characteristic><characteristic name="A" typeId="6b9f-c8fe-8998-27e3">3</characteristic><characteristic name="Ld" typeId="2d45-18fe-9eb3-b113"></characteristic></characteristics></profile></profiles><selections><selection id="7c973kg" name="Armour Save 5+" entryId="4b9c-348c-8dc6-efdf" number="1" type="upgrade" from="entry"></selection></selections><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="165" /></costs><categories><category id="43cc-fc3f-35a7-8d03" entryId="43cc-fc3f-35a7-8d03" name="Special" primary="true" /></categories></selection><selection id="8d15inc" name="Leadbelchers" entryId="da30-4b49-acc3-21a7" number="1" type="unit" from="entry"><rules><rule id="8953-90f3-edab-81fe" name="Bull Charge" hidden="false" page="16"><description>Any unit consisting of three or more Ogre models (Tyrants. Bruisers. Slaughtemiasters• Butchers. Bulls. Ironguts. Inadbeichers. and Maneaters) on any turn when all models in that unit charge 6” or more, may Inflict one impact hit per Ogre in base contact with an enemy model. This is resolved at the model's basic Strength. So. for instance. a unit of three Ogre Bulls with a Bruiser leading it, all of whom arc in base contact with the enemy. would inflict three Strength 4 impact hits and one Strength 5 impact hit.</description></rule><rule id="1524-2372-4aa0-6881" name="Fear" hidden="false" page="81"><description>Unit causes Fear</description></rule></rules><profiles><profile id="0827-0dad-f5b2-fea5" name="Ogre Bull" hidden="false" typeId="a54a-7f00-29bf-12b1" typeName="Profile" from="entry"><characteristics><characteristic name="Mv" typeId="0e92-d038
<roster id="jllmpcm" name="Kineater mit AST" battleScribeVersion="2.03" generatedBy="https://newrecruit.eu" gameSystemId="6d8e-38d9-3c69-febf" gameSystemName="Warhammer Fantasy Battle 6th edition" gameSystemRevision="9" xmlns="http://www.battlescribe.net/schema/rosterSchema"><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="2000" /><cost name="Casting Dice" typeId="fcec-2340-6368-a2ba" value="6" /><cost name="Dispel Dice" typeId="6001-b2bf-4529-c07d" value="4" /></costs><costLimits><costLimit name="pts" typeId="ecfa-8486-4f6c-c249" value="2000" /><costLimit name="Casting Dice" typeId="fcec-2340-6368-a2ba" value="8" /></costLimits><forces><force id="k9sgadd" name="Standard" entryId="7d9d-6c8d-4ea0-b7ad" catalogueId="731d-5b13-2a92-5426" catalogueRevision="1" catalogueName="Ogre Kingdoms"><selections><selection id="5uufgxo" name="Tyrant" entryId="2679-58f4-1771-662d" number="1" type="unit" from="entry"><rules><rule id="1524-2372-4aa0-6881" name="Fear" hidden="false" page="81"><description>Unit causes Fear</description></rule><rule id="8953-90f3-edab-81fe" name="Bull Charge" hidden="false" page="16"><description>Any unit consisting of three or more Ogre models (Tyrants. Bruisers. Slaughtemiasters• Butchers. Bulls. Ironguts. Inadbeichers. and Maneaters) on any turn when all models in that unit charge 6” or more, may Inflict one impact hit per Ogre in base contact with an enemy model. This is resolved at the model's basic Strength. So. for instance. a unit of three Ogre Bulls with a Bruiser leading it, all of whom arc in base contact with the enemy. would inflict three Strength 4 impact hits and one Strength 5 impact hit.</description></rule></rules><profiles><profile id="6efd-d96c-c358-d0c8" name="Tyrant" hidden="false" typeId="a54a-7f00-29bf-12b1" typeName="Profile" from="entry"><characteristics><characteristic name="Mv" typeId="0e92-d038-82bf-fb41">6</characteristic><characteristic name="WS" typeId="f95b-da01-0578-3bdc">6</characteristic><characteristic name="BS" typeId="4a8b-0c8e-3daf-7901">4</characteristic><characteristic name="S" typeId="b690-4bc0-bb73-267b">5</characteristic><characteristic name="T" typeId="8712-f56f-5b22-a720">5</characteristic><characteristic name="W" typeId="253a-9b00-4fde-8ac2">5</characteristic><characteristic name="I" typeId="dfff-363e-f72a-5a59">4</characteristic><characteristic name="A" typeId="6b9f-c8fe-8998-27e3">5</characteristic><characteristic name="Ld" typeId="2d45-18fe-9eb3-b113">9</characteristic></characteristics></profile></profiles><selections><selection id="6ssvy2" name="General" entryId="7c00-fde2-07b8-802c::1b7c-2c90-6d96-28c9" number="1" type="upgrade" from="entry"><costs><cost name="Casting Dice" typeId="fcec-2340-6368-a2ba" value="2" /><cost name="Dispel Dice" typeId="6001-b2bf-4529-c07d" value="2" /></costs><categories><category id="a37e-7207-de6d-acb0" name="General" entryId="a37e-7207-de6d-acb0" primary="false" /></categories></selection><selection id="6rufiz" name="Ogre Club" entryId="d147-4027-3433-9add::8768-377c-88da-c3e8" number="1" type="upgrade" from="entry"><rules><rule id="581c-88a8-06c9-95a4" name="Ogre Club" hidden="false"><description>A Hand weapon that mangles armour. An additional -1 to the armour save unless used with an additioanl weapon or ironfist.</description></rule></rules><profiles><profile id="3af4-0e06-e906-b5b3" name="Ogre Club" hidden="false" typeId="7889-42d9-70a0-3ea9" typeName="Weapon" from="entry"><characteristics><characteristic name="Range" typeId="3107-4d1e-9a51-6564">CC</characteristic><characteristic name="Strength" typeId="6fe4-1ebb-cb04-1378">As user</characteristic><characteristic name="Special Rules" typeId="a21a-cdc0-4b13-b236">Treat as a hand weapon but gives an additional -1 to the Armour Save</characteristic></characteristics></profile></profiles></selection><selection id="6rql8a" name="Heavy Armour" entryId="8d03-ca43-d6b4-c103::dde4-0ba8-7b3c-57b7" entryGroupId="3668-9d1a-d2b4-acf2" number="1" type="upgrade" from="group" group="Armour"><profiles><profile id="3dd5-f228-98a7-453a" name="Heavy Armour" hidden="false" typeId="f681-9937-db53-f1d8" typeName="Armour" from="entry"><characteristics><characteristic name="Saving Throw Modifier" typeId="b600-e1ed-0765-27c1">5+</characteristic><characteristic name="Special rules" typeId="42c3-68ab-cfa5-203e"></characteristic></characteristics></profile></profiles><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="6" /></costs></selection><selection id="pttf6im" name="Kineater" entryId="298a-8356-cf73-8dd7::55cb-3334-b1fa-c963::b82a-890d-0d19-c653" entryGroupId="298a-8356-cf73-8dd7::be5e-0c92-4eec-1335" number="1" type="upgrade" from="group" group="MAgic Items anD biG naMeS::Big Names"><rules><rule id="e6d0-5673-45a7-b451" name="Kineater" hidden="false"><description>Units may reroll failed Panic test if within 6&quot; of the Kineater.</description></rule></rules><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="35" /></costs></selection><selection id="66n8s1r" name="Tenderiser" entryId="4a52-bad1-903c-cd59::63e5-0125-593e-0cac::285e-d264-6dc1-cb91" entryGroupId="4a52-bad1-903c-cd59::e826-8d77-2f41-9ee4" number="1" type="upgrade" from="group" group="MAgic Items anD biG naMeS::Magic Weapons"><rules><rule id="ddb5-786a-48c6-43bc" name="Tenderiser" hidden="false"><description>The Tenderiser is a two handed weapon that follows the rules for great weapons. Any model wounded by the tenderiser takes not 1 but D3 wounds.</description></rule></rules><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="50" /></costs></selection></selections><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="200" /></costs><categories><category id="d024-d25b-a9b4-73b6" entryId="d024-d25b-a9b4-73b6" name="Lord" primary="true" /></categories></selection><selection id="vocrha9" name="Bruiser" entryId="d097-a3de-898f-91c8" number="1" type="unit" from="entry"><rules><rule id="1524-2372-4aa0-6881" name="Fear" hidden="false" page="81"><description>Unit causes Fear</description></rule><rule id="8953-90f3-edab-81fe" name="Bull Charge" hidden="false" page="16"><description>Any unit consisting of three or more Ogre models (Tyrants. Bruisers. Slaughtemiasters• Butchers. Bulls. Ironguts. Inadbeichers. and Maneaters) on any turn when all models in that unit charge 6” or more, may Inflict one impact hit per Ogre in base contact with an enemy model. This is resolved at the model's basic Strength. So. for instance. a unit of three Ogre Bulls with a Bruiser leading it, all of whom arc in base contact with the enemy. would inflict three Strength 4 impact hits and one Strength 5 impact hit.</description></rule></rules><profiles><profile id="29ad-087e-b593-12a2" name="Bruiser" hidden="false" typeId="a54a-7f00-29bf-12b1" typeName="Profile" from="entry"><characteristics><characteristic name="Mv" typeId="0e92-d038-82bf-fb41">6</characteristic><characteristic name="WS" typeId="f95b-da01-0578-3bdc">5</characteristic><characteristic name="BS" typeId="4a8b-0c8e-3daf-7901">3</characteristic><characteristic name="S" typeId="b690-4bc0-bb73-267b">5</characteristic><characteristic name="T" typeId="8712-f56f-5b22-a720">5</characteristic><characteristic name="W" typeId="253a-9b00-4fde-8ac2">4</characteristic><characteristic name="I" typeId="dfff-363e-f72a-5a59">3</characteristic><characteristic name="A" typeId="6b9f-c8fe-8998-27e3">4</characteristic><characteristic name="Ld" typeId="2d45-18fe-9eb3-b113">8</characteristic></characteristics></profile></profiles><selections><selection id="w790xt" name="Battle Standard Bearer" entryId="314e-f3c5-da87-eb75::e9ad-f1ce-aebf-6d23" number="1" type="upgrade" from="entry"><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="25" /></costs></selection><selection id="w6elh3p" name="Ogre Club" entryId="3836-774f-6bcd-1463::8768-377c-88da-c3e8" number="1" type="upgrade" from="entry"><rules><rule id="581c-88a8-06c9-95a4" name="Ogre Club" hidden="false"><description>A Hand weapon that mangles armour. An additional -1 to the armour save unless used with an additioanl weapon or ironfist.</description></rule></rules><profiles><profile id="3af4-0e06-e906-b5b3" name="Ogre Club" hidden="false" typeId="7889-42d9-70a0-3ea9" typeName="Weapon" from="entry"><characteristics><characteristic name="Range" typeId="3107-4d1e-9a51-6564">CC</characteristic><characteristic name="Strength" typeId="6fe4-1ebb-cb04-1378">As user</characteristic><characteristic name="Special Rules" typeId="a21a-cdc0-4b13-b236">Treat as a hand weapon but gives an additional -1 to the Armour Save</characteristic></characteristics></profile></profiles></selection><selection id="w72yfbq" name="Sword Gnoblar" entryId="92ef-c906-8724-a40a::3562-2b92-9516-014d" number="1" type="upgrade" from="entry"><rules><rule id="4b9b-0a7c-54e1-c0a2" name="Sword Gnoblars " hidden="false" page="23"><description>An Ogre with Sword-Gnoblars benefits from one extra Strength 2 attack per combat round per Sword-Gnoblar in his possession. at the Weapon Skill of the owning model (the opponent's attention is elsewhere!). These attacks are made at the same time as the owning character's attacks and must be directed at models the Ogre character has directed attacks coward.
Note: Sword•Gnoblars are represented on the character model the) accompany: they do not occupy their own bases or have their own characteristics like 'normal' Gnoblars.</description></rule></rules><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="5" /></costs></selection><selection id="x3qhqjg" name="Heavy Armour" entryId="2d13-9ea1-c210-539b::dde4-0ba8-7b3c-57b7" entryGroupId="b3bc-0f88-fd9e-0078" number="1" type="upgrade" from="group" group="Armour"><profiles><profile id="3dd5-f228-98a7-453a" name="Heavy Armour" hidden="false" typeId="f681-9937-db53-f1d8" typeName="Armour" from="entry"><characteristics><characteristic name="Saving Throw Modifier" typeId="b600-e1ed-0765-27c1">5+</characteristic><characteristic name="Special rules" typeId="42c3-68ab-cfa5-203e"></characteristic></characteristics></profile></profiles><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="4" /></costs></selection><selection id="vz7f2bo" name="Sword of Might" entryId="b1cb-0509-d4b2-009a::ea7a-374f-5b03-1b68::8c56-9be1-c4a9-5afe" entryGroupId="b1cb-0509-d4b2-009a::e826-8d77-2f41-9ee4" number="1" type="upgrade" from="group" group="MAgic Items anD biG naMeS::Magic Weapons"><profiles><profile id="c9ca-e793-d620-9f47" name="Sword of Might" hidden="false" typeId="7889-42d9-70a0-3ea9" typeName="Weapon" from="entry"><characteristics><characteristic name="Range" typeId="3107-4d1e-9a51-6564">cc</characteristic><characteristic name="Strength" typeId="6fe4-1ebb-cb04-1378">User +1 S</characteristic><characteristic name="Special Rules" typeId="a21a-cdc0-4b13-b236">Adds +1 Strength</characteristic></characteristics></profile></profiles><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="20" /></costs></selection></selections><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="130" /></costs><categories><category id="c16b-f319-2c62-2c12" entryId="c16b-f319-2c62-2c12" name="Heroes" primary="true" /></categories></selection><selection id="shby6ma" name="Butcher" entryId="8933-af8e-e780-6f48" number="1" type="unit" from="entry"><rules><rule id="1524-2372-4aa0-6881" name="Fear" hidden="false" page="81"><description>Unit causes Fear</description></rule><rule id="8953-90f3-edab-81fe" name="Bull Charge" hidden="false" page="16"><description>Any unit consisting of three or more Ogre models (Tyrants. Bruisers. Slaughtemiasters• Butchers. Bulls. Ironguts. Inadbeichers. and Maneaters) on any turn when all models in that unit charge 6” or more, may Inflict one impact hit per Ogre in base contact with an enemy model. This is resolved at the model's basic Strength. So. for instance. a unit of three Ogre Bulls with a Bruiser leading it, all of whom arc in base contact with the enemy. would inflict three Strength 4 impact hits and one Strength 5 impact hit.</description></rule><rule id="5f8f-54bc-1fdc-b724" name="Immune to Poison" hidden="false"><description/></rule></rules><profiles><profile id="03fe-a4de-522c-195e" name="Butcher" hidden="false" typeId="a54a-7f00-29bf-12b1" typeName="Profile" from="entry"><characteristics><characteristic name="Mv" typeId="0e92-d038-82bf-fb41">6</characteristic><characteristic name="WS" typeId="f95b-da01-0578-3bdc">3</characteristic><characteristic name="BS" typeId="4a8b-0c8e-3daf-7901">2</characteristic><characteristic name="S" typeId="b690-4bc0-bb73-267b">4</characteristic><characteristic name="T" typeId="8712-f56f-5b22-a720">5</characteristic><characteristic name="W" typeId="253a-9b00-4fde-8ac2">4</characteristic><characteristic name="I" typeId="dfff-363e-f72a-5a59">2</characteristic><characteristic name="A" typeId="6b9f-c8fe-8998-27e3">3</characteristic><characteristic name="Ld" typeId="2d45-18fe-9eb3-b113">7</characteristic></characteristics></profile></profiles><selections><selection id="ss8p3k" name="Hand Weapon" entryId="8b61-79ab-f251-234b::abdb-bbd0-41b2-5dff" number="1" type="upgrade" from="entry"><profiles><profile id="5556-38ea-b278-4a8f" name="Hand Weapon" hidden="false" typeId="7889-42d9-70a0-3ea9" typeName="Weapon" from="entry"><characteristics><characteristic name="Range" typeId="3107-4d1e-9a51-6564">CC only</characteristic><characteristic name="Strength" typeId="6fe4-1ebb-cb04-1378">As User</characteristic><characteristic name="Special Rules" typeId="a21a-cdc0-4b13-b236"></characteristic></characteristics></profile></profiles></selection><selection id="st7t0q" name="Tooth Gnoblar" entryId="8844-57ba-d94e-07f8::76ae-6ff0-fa70-3d21" number="2" type="upgrade" from="entry"><rules><rule id="7d3f-f9b5-cb8f-c098" name="Tooth-Gnoblars" hidden="false" page="25"><description>Before attempting to cast a Gut Magic spell, an Ogre Butcher with Tooth-Gnoblars may choose to sacrifice one to get +1 to the total casting value of that Shamanic Victual. Each Thoth-Gnoblar can only be sacrificed once per battle, but a Butcher with two Thoth-Gnoblars may choose to sacrifice both at once for +2 to his casting value if he so wishes.
Note: Thoth-Gnoblars are represented on the character model they accompany; they do not occupy their own bases or have their own characteristics like 'normal' Gnoblars.</description></rule></rules><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="10" /></costs></selection><selection id="sspfjg" name="Skullmantle" entryId="c5ed-e4a2-689a-ae42::2b2e-55f4-12ec-7fd1::5ccf-df71-8c78-ee5e" entryGroupId="c5ed-e4a2-689a-ae42::4c3e-febe-6d5d-6912" number="1" type="upgrade" from="group" group="MAgic Items anD biG naMeS::Arcane Items"><rules><rule id="e998-33cd-39f2-722f" name="Skullmantle" hidden="false"><description>Any enemy unit forced to take any Leadership tests (including Psychology and Break tests) due to the Butcher wearing the Skull Mantle, or a unit he has joined, suffers a -1 penalty to their Leadership.</description></rule></rules><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="20" /></costs></selection><selection id="sog9m3a" name="Siegebreaker" entryId="15e9-b34f-283b-673c::d5a7-e9a3-cbbb-31b6::904a-d1ae-4f88-1df9" entryGroupId="15e9-b34f-283b-673c::ccd0-c3c7-6cae-b491" number="1" type="upgrade" from="group" group="MAgic Items anD biG naMeS::Magic Weapons Butcher"><rules><rule id="200e-15e6-a46a-92f6" name="Siegebreaker" hidden="false"><description>The Tenderiser is a two handed weapon that follows the rules for great weapons, but adds +3 Str instead of +2. When rolling to hit compare the Ogres WS to the opponents Iniative. Targets without Iniative are automatically hit and take D6 wounds instead of 1.</description></rule></rules><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="30" /></costs></selection></selections><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="130" /><cost name="Casting Dice" typeId="fcec-2340-6368-a2ba" value="2" /><cost name="Dispel Dice" typeId="6001-b2bf-4529-c07d" value="1" /></costs><categories><category id="c16b-f319-2c62-2c12" entryId="c16b-f319-2c62-2c12" name="Heroes" primary="true" /></categories></selection><selection id="ps8wnv" name="Butcher" entryId="8933-af8e-e780-6f48" number="1" type="unit" from="entry"><rules><rule id="1524-2372-4aa0-6881" name="Fear" hidden="false" page="81"><description>Unit causes Fear</description></rule><rule id="8953-90f3-edab-81fe" name="Bull Charge" hidden="false" page="16"><description>Any unit consisting of three or more Ogre models (Tyrants. Bruisers. Slaughtemiasters• Butchers. Bulls. Ironguts. Inadbeichers. and Maneaters) on any turn when all models in that unit charge 6” or more, may Inflict one impact hit per Ogre in base contact with an enemy model. This is resolved at the model's basic Strength. So. for instance. a unit of three Ogre Bulls with a Bruiser leading it, all of whom arc in base contact with the enemy. would inflict three Strength 4 impact hits and one Strength 5 impact hit.</description></rule><rule id="5f8f-54bc-1fdc-b724" name="Immune to Poison" hidden="false"><description/></rule></rules><profiles><profile id="03fe-a4de-522c-195e" name="Butcher" hidden="false" typeId="a54a-7f00-29bf-12b1" typeName="Profile" from="entry"><characteristics><characteristic name="Mv" typeId="0e92-d038-82bf-fb41">6</characteristic><characteristic name="WS" typeId="f95b-da01-0578-3bdc">3</characteristic><characteristic name="BS" typeId="4a8b-0c8e-3daf-7901">2</characteristic><characteristic name="S" typeId="b690-4bc0-bb73-267b">4</characteristic><characteristic name="T" typeId="8712-f56f-5b22-a720">5</characteristic><characteristic name="W" typeId="253a-9b00-4fde-8ac2">4</characteristic><characteristic name="I" typeId="dfff-363e-f72a-5a59">2</characteristic><characteristic name="A" typeId="6b9f-c8fe-8998-27e3">3</characteristic><characteristic name="Ld" typeId="2d45-18fe-9eb3-b113">7</characteristic></characteristics></profile></profiles><selections><selection id="q6h6p9p" name="Hand Weapon" entryId="8b61-79ab-f251-234b::abdb-bbd0-41b2-5dff" number="1" type="upgrade" from="entry"><profiles><profile id="5556-38ea-b278-4a8f" name="Hand Weapon" hidden="false" typeId="7889-42d9-70a0-3ea9" typeName="Weapon" from="entry"><characteristics><characteristic name="Range" typeId="3107-4d1e-9a51-6564">CC only</characteristic><characteristic name="Strength" typeId="6fe4-1ebb-cb04-1378">As User</characteristic><characteristic name="Special Rules" typeId="a21a-cdc0-4b13-b236"></characteristic></characteristics></profile></profiles></selection><selection id="q7bqjk" name="Tooth Gnoblar" entryId="8844-57ba-d94e-07f8::76ae-6ff0-fa70-3d21" number="2" type="upgrade" from="entry"><rules><rule id="7d3f-f9b5-cb8f-c098" name="Tooth-Gnoblars" hidden="false" page="25"><description>Before attempting to cast a Gut Magic spell, an Ogre Butcher with Tooth-Gnoblars may choose to sacrifice one to get +1 to the total casting value of that Shamanic Victual. Each Thoth-Gnoblar can only be sacrificed once per battle, but a Butcher with two Thoth-Gnoblars may choose to sacrifice both at once for +2 to his casting value if he so wishes.
Note: Thoth-Gnoblars are represented on the character model they accompany; they do not occupy their own bases or have their own characteristics like 'normal' Gnoblars.</description></rule></rules><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="10" /></costs></selection><selection id="q45xra" name="Bangstick" entryId="c5ed-e4a2-689a-ae42::f7d4-c610-84a1-2796::c5d0-f7e9-6534-f6f4" entryGroupId="c5ed-e4a2-689a-ae42::4c3e-febe-6d5d-6912" number="1" type="upgrade" from="group" group="MAgic Items anD biG naMeS::Arcane Items"><rules><rule id="f706-23c7-b76f-b803" name="Bangstick" hidden="false"><description>Bound spell - power level 3
The Bangstick may be used once per turn to cast a magic missile with a 24&quot; range, causing D6 Sa hits. Line of sight may be freely drawn through friendly unengaged Gnoblar units, which will also sustain D6 S4 hits in exactly the same manner as the target.</description></rule></rules><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="25" /></costs></selection><selection id="q3952qu" name="Dispel Scroll" entryId="c5ed-e4a2-689a-ae42::1954-4ffd-5be0-eac7::b76c-6bad-4650-dbb0" entryGroupId="c5ed-e4a2-689a-ae42::4c3e-febe-6d5d-6912" number="1" type="upgrade" from="group" group="MAgic Items anD biG naMeS::Arcane Items"><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="25" /></costs></selection></selections><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="130" /><cost name="Casting Dice" typeId="fcec-2340-6368-a2ba" value="2" /><cost name="Dispel Dice" typeId="6001-b2bf-4529-c07d" value="1" /></costs><categories><category id="c16b-f319-2c62-2c12" entryId="c16b-f319-2c62-2c12" name="Heroes" primary="true" /></categories></selection><selection id="69b5b1011ad408e8cf8d7f5e" name="Bulls" entryId="7754-8b3d-df99-d2d5" number="1" type="unit" from="entry"><rules><rule id="8953-90f3-edab-81fe" name="Bull Charge" hidden="false" page="16"><description>Any unit consisting of three or more Ogre models (Tyrants. Bruisers. Slaughtemiasters• Butchers. Bulls. Ironguts. Inadbeichers. and Maneaters) on any turn when all models in that unit charge 6” or more, may Inflict one impact hit per Ogre in base contact with an enemy model. This is resolved at the model's basic Strength. So. for instance. a unit of three Ogre Bulls with a Bruiser leading it, all of whom arc in base contact with the enemy. would inflict three Strength 4 impact hits and one Strength 5 impact hit.</description></rule><rule id="1524-2372-4aa0-6881" name="Fear" hidden="false" page="81"><description>Unit causes Fear</description></rule></rules><profiles><profile id="0827-0dad-f5b2-fea5" name="Ogre Bull" hidden="false" typeId="a54a-7f00-29bf-12b1" typeName="Profile" from="entry"><characteristics><characteristic name="Mv" typeId="0e92-d038-82bf-fb41">6</characteristic><characteristic name="WS" typeId="f95b-da01-0578-3bdc">3</characteristic><characteristic name="BS" typeId="4a8b-0c8e-3daf-7901">2</characteristic><characteristic name="S" typeId="b690-4bc0-bb73-267b">4</characteristic><characteristic name="T" typeId="8712-f56f-5b22-a720">4</characteristic><characteristic name="W" typeId="253a-9b00-4fde-8ac2">3</characteristic><characteristic name="I" typeId="dfff-363e-f72a-5a59">2</characteristic><characteristic name="A" typeId="6b9f-c8fe-8998-27e3">3</characteristic><characteristic name="Ld" typeId="2d45-18fe-9eb3-b113">7</characteristic></characteristics></profile></profiles><selections><selection id="qbsbl2i" name="Bellower" entryId="5bdc-7455-df90-94da" number="1" type="upgrade" from="entry"><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="10" /></costs></selection><selection id="2pzley" name="Bulls" entryId="411b-6f5f-06f1-be37" number="4" type="model" from="entry"><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="140" /></costs></selection><selection id="xf5b4" name="Light Armour" entryId="e5af-d4b8-8f97-9197::055f-8e4e-f170-35d2" number="1" type="upgrade" from="entry"><profiles><profile id="752a-95b9-343a-8f75" name="Light Armour" hidden="false" typeId="f681-9937-db53-f1d8" typeName="Armour" from="entry"><characteristics><characteristic name="Saving Throw Modifier" typeId="b600-e1ed-0765-27c1">6+</characteristic><characteristic name="Special rules" typeId="42c3-68ab-cfa5-203e"></characteristic></characteristics></profile></profiles><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="12" /></costs></selection><selection id="2r2ckcc" name="Ogre Club" entryId="415f-94c9-571c-19c6::8768-377c-88da-c3e8" number="1" type="upgrade" from="entry"><rules><rule id="581c-88a8-06c9-95a4" name="Ogre Club" hidden="false"><description>A Hand weapon that mangles armour. An additional -1 to the armour save unless used with an additioanl weapon or ironfist.</description></rule></rules><profiles><profile id="3af4-0e06-e906-b5b3" name="Ogre Club" hidden="false" typeId="7889-42d9-70a0-3ea9" typeName="Weapon" from="entry"><characteristics><characteristic name="Range" typeId="3107-4d1e-9a51-6564">CC</characteristic><characteristic name="Strength" typeId="6fe4-1ebb-cb04-1378">As user</characteristic><characteristic name="Special Rules" typeId="a21a-cdc0-4b13-b236">Treat as a hand weapon but gives an additional -1 to the Armour Save</characteristic></characteristics></profile></profiles></selection><selection id="xf0dag" name="Ogre Ironfist" entryId="311b-bc83-3879-5f60::eda9-144c-2625-da8e" entryGroupId="0822-61e1-2618-e1d1" number="1" type="upgrade" from="group" group="Extra Wepon Selection"><rules><rule id="cea6-5f14-80ce-5f86" name="Iron Fist" hidden="false" page="29"><description>At the begin of each Close combat, Ogres may use the Iron fist as an extra handweapon or as a shield. When used as a shield gain Sword+Board.</description></rule></rules><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="20" /></costs></selection></selections><categories><category id="64bf-efb4-9978-26df" entryId="64bf-efb4-9978-26df" name="Core" primary="true" /><category id="735e-2da1-6356-2fdb" name="Bully Bully" entryId="735e-2da1-6356-2fdb" primary="false" /></categories></selection><selection id="69bc38e6bf2b34e115e052df" name="Bulls" entryId="7754-8b3d-df99-d2d5" number="1" type="unit" from="entry"><rules><rule id="8953-90f3-edab-81fe" name="Bull Charge" hidden="false" page="16"><description>Any unit consisting of three or more Ogre models (Tyrants. Bruisers. Slaughtemiasters• Butchers. Bulls. Ironguts. Inadbeichers. and Maneaters) on any turn when all models in that unit charge 6” or more, may Inflict one impact hit per Ogre in base contact with an enemy model. This is resolved at the model's basic Strength. So. for instance. a unit of three Ogre Bulls with a Bruiser leading it, all of whom arc in base contact with the enemy. would inflict three Strength 4 impact hits and one Strength 5 impact hit.</description></rule><rule id="1524-2372-4aa0-6881" name="Fear" hidden="false" page="81"><description>Unit causes Fear</description></rule></rules><profiles><profile id="0827-0dad-f5b2-fea5" name="Ogre Bull" hidden="false" typeId="a54a-7f00-29bf-12b1" typeName="Profile" from="entry"><characteristics><characteristic name="Mv" typeId="0e92-d038-82bf-fb41">6</characteristic><characteristic name="WS" typeId="f95b-da01-0578-3bdc">3</characteristic><characteristic name="BS" typeId="4a8b-0c8e-3daf-7901">2</characteristic><characteristic name="S" typeId="b690-4bc0-bb73-267b">4</characteristic><characteristic name="T" typeId="8712-f56f-5b22-a720">4</characteristic><characteristic name="W" typeId="253a-9b00-4fde-8ac2">3</characteristic><characteristic name="I" typeId="dfff-363e-f72a-5a59">2</characteristic><characteristic name="A" typeId="6b9f-c8fe-8998-27e3">3</characteristic><characteristic name="Ld" typeId="2d45-18fe-9eb3-b113">7</characteristic></characteristics></profile></profiles><selections><selection id="fbi2hg" name="Bellower" entryId="5bdc-7455-df90-94da" number="1" type="upgrade" from="entry"><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="10" /></costs></selection><selection id="fafad4w" name="Bulls" entryId="411b-6f5f-06f1-be37" number="4" type="model" from="entry"><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="140" /></costs></selection><selection id="fd92mtk" name="Light Armour" entryId="e5af-d4b8-8f97-9197::055f-8e4e-f170-35d2" number="1" type="upgrade" from="entry"><profiles><profile id="752a-95b9-343a-8f75" name="Light Armour" hidden="false" typeId="f681-9937-db53-f1d8" typeName="Armour" from="entry"><characteristics><characteristic name="Saving Throw Modifier" typeId="b600-e1ed-0765-27c1">6+</characteristic><characteristic name="Special rules" typeId="42c3-68ab-cfa5-203e"></characteristic></characteristics></profile></profiles><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="12" /></costs></selection><selection id="fdhy79k" name="Ogre Club" entryId="415f-94c9-571c-19c6::8768-377c-88da-c3e8" number="1" type="upgrade" from="entry"><rules><rule id="581c-88a8-06c9-95a4" name="Ogre Club" hidden="false"><description>A Hand weapon that mangles armour. An additional -1 to the armour save unless used with an additioanl weapon or ironfist.</description></rule></rules><profiles><profile id="3af4-0e06-e906-b5b3" name="Ogre Club" hidden="false" typeId="7889-42d9-70a0-3ea9" typeName="Weapon" from="entry"><characteristics><characteristic name="Range" typeId="3107-4d1e-9a51-6564">CC</characteristic><characteristic name="Strength" typeId="6fe4-1ebb-cb04-1378">As user</characteristic><characteristic name="Special Rules" typeId="a21a-cdc0-4b13-b236">Treat as a hand weapon but gives an additional -1 to the Armour Save</characteristic></characteristics></profile></profiles></selection><selection id="fcq4t1c" name="Ogre Ironfist" entryId="311b-bc83-3879-5f60::eda9-144c-2625-da8e" entryGroupId="0822-61e1-2618-e1d1" number="1" type="upgrade" from="group" group="Extra Wepon Selection"><rules><rule id="cea6-5f14-80ce-5f86" name="Iron Fist" hidden="false" page="29"><description>At the begin of each Close combat, Ogres may use the Iron fist as an extra handweapon or as a shield. When used as a shield gain Sword+Board.</description></rule></rules><costs><cost name="pts" typeId="ecfa-8486-4f6c-c249" value="20" /></costs></selection></selections><categories><category id="64bf-efb4-9978-26df" entryId="64bf-efb4-9978-26df" name="Core" primary="true" /><category id="735e-2da1-6356-2fdb" name="Bully Bully" entryId="735e-2da1-6356-2fdb" primary="false" /></categories></selection><selection id="td73gj" name="Gnoblar Trappers" entryId="041b-7d95-6ff9-754a" number="1" type="unit" from="entry"><rules><rule id="e007-03a5-4355-1b42" name="Bicker" hidden="false"><description>If not in combat or subject to compulsory movement, at teh start of the turn roll a D6 for each unit of gnoblars. On a 1 they do nothing this turn.</description></rule><rule id="68bc-79d5-4bd1-1736" name="Largely Insignificant" hidden="false"><description>Gnoblars do not cause panic in other units for fleeing, break from combat or are destroyed.</description></rule><rule id="889c-dfc3-95a5-2d30" name="Scouts" hidden="false"><description>These troops are skilled at sneaking forwards to scout out the enemy before the main force arrives. By making the best use of cover, advancing at night, or with other troops providing a diversion, they are able to deploy ahead of the rest of the army.
Scouts are set up after both armies have been deployed. They can be set up anywhere on the table, at least 10&quot; away from the enemy and must be out of the sight of any enemy troops and in or behind interposing terrain (not out in the open!). If both armies contain troops with this ability, each player should roll a D6, with the player scoring the highest choosing whether he deploys before or after the enemy's Scouts. Two opposing groups of Scouts cannot be set up within 10&quot; of each other.
Alternatively, Scouts can be placed on the controlling player's deployment zone like any other troops, after deployment of both main armies is finished.</description></rule></rules><profiles><profile id="839c-04bb-9e86-9a1f" name="Trapper" hidden="false" typeId="a54a-7f00-29bf-12b1" typeName="Profile" from="entry"><characteristics><characteristic name="Mv" typeId="0e92-d038-82bf-fb41">4</characteristic><characteristic name="WS" typeId="f95b-da01-0578-3bdc">2</characteristic><characteristic name="BS" typeId="4a8b-0c8e-3daf-7901">3</characteristic><characteristic name="S" typeId="b690-4bc0-bb73-267b">2</characteristic><characteristic name="T" typeId="8712-f56f-5b22-a720">3</characteristic><characteristic name="W" typeId="253a-9b00-4fde-8ac2">1</characteristic><characteristic name="I" typeId="dfff-363e-f72a-5a59">3</characteristic><characteristic name="A" typeId="6b9f-c8fe-8998-27e3">1</characteristic><characteristic name="Ld" typeId="2d45-18fe-9eb3-b113">5</characteristic></characteristics></profile></profiles><selections><selection id="tgzewm6" name="Hand Weapon" entryId="76f8-9d1f-6e05-cef7::abdb-bbd0-41b2-5dff" number="1" type="upgrade" from="entry"><profiles><profile id="5556-38ea-b278-4a8f" name="Hand Weapon" hidden="false" typeId="7889-42d9-70a0-3ea9" typeName="Weapon" from="entry"><characteristics><characteristic name="Range" typeId="3107-4d1e-9a51-6564">CC only</characteristic><characteristic name="Strength" typeId="6fe4-1ebb-cb04-1378">As User</characteristic><characteristic name="Special Rules" typeId="a21a-cdc0-4b13-b236"></characteristic></characteristics></profile></profiles></selection><selection id="tgqjcte" name="Sharp Stuff" entryId="2fbc-0257-8771-cf03::5545-fcf3-a765-9474" number="1" type="upgrade" from="entry"><profiles><profile id="68cd-6519-6e48-36f5" name="Sharp Stuff" hidden="false" typeId="7889-42d9-70a0-3ea9" typeName="Weapon" from="entry"><characteristics><characteristic name="Range" typeId="3107-4d1e-9a51-6564">8&quot;</characteristic><characteristic name="Strength" typeId="6fe4-1ebb-cb04-1378">2</characteristic><characteristic name="Special Rules" typeId="a21a-cdc0-4b13-b236">2x Multishot
